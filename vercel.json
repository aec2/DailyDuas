{
  "framework": null,
  "buildCommand": "node scripts/generate-screenshots.mjs && ng build",
  "outputDirectory": "dist/app/browser",
  "routes": [
    {
      "src": "/ngsw-worker.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Content-Type": "application/javascript",
        "Service-Worker-Allowed": "/"
      },
      "dest": "/ngsw-worker.js"
    },
    {
      "src": "/ngsw.json",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" },
      "dest": "/ngsw.json"
    },
    {
      "src": "/manifest.webmanifest",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "no-cache"
      },
      "dest": "/manifest.webmanifest"
    },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/screenshots/(.*)", "dest": "/screenshots/$1" },
    { "src": "/(.*\\.(js|css|woff2?|ttf|eot|ico|svg|png|jpg|jpeg|webp|avif|gif|txt|xml|json))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
